<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:base="clr-namespace:Voidstrap.UI.Elements.Base">

    <!-- Bustrap: cool teal + black theme -->
    <!-- Teal bright: #26DCC7, Teal deep: #085C6E, Black: #080C12 -->

    <SolidColorBrush x:Key="NewTextEditorBackground" Color="#0A1A1F" />
    <SolidColorBrush x:Key="NewTextEditorForeground" Color="#5AF5DC" />
    <SolidColorBrush x:Key="NewTextEditorLink" Color="#26DCC7" />
    <SolidColorBrush x:Key="PrimaryBackgroundColor" Color="#0A1A1F" />

    <Color x:Key="ControlFillColorDefault">#CC0A1A1F</Color>

    <Color x:Key="WindowBackgroundColorPrimary">#26DCC7</Color>
    <Color x:Key="WindowBackgroundColorSecondary">#085C6E</Color>
    <Color x:Key="WindowBackgroundColorThird">#080C12</Color>

    <Color x:Key="WindowBackgroundColorPrimaryWithOpacity">#8026DCC7</Color>
    <Color x:Key="WindowBackgroundColorSecondaryWithOpacity">#80085C6E</Color>
    <Color x:Key="WindowBackgroundColorThirdWithOpacity">#80080C12</Color>

</ResourceDictionary>
